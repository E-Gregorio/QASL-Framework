# ============================================================================
# Static Analyzer (QASL Framework) - Variables de entorno (TEMPLATE PÚBLICO)
# ============================================================================
# Copiá este archivo a .env y reemplazá los placeholders con tus valores.
# El archivo .env real está en .gitignore para no exponer secretos.
#
#   cp .env.example .env
#
# API key de Anthropic: https://console.anthropic.com/settings/keys
# ============================================================================

ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Modelo de Claude (opcional - default: claude-sonnet-4-5)
#   - claude-sonnet-4-5    rápido y económico, buena calidad
#   - claude-opus-4        máxima calidad, más caro
ANTHROPIC_MODEL=claude-sonnet-4-5
